<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_margin="4dp"
             app:cardCornerRadius="8dp"
             app:cardElevation="2dp"
             app:cardUseCompatPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/content_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground">

        <View
                android:id="@+id/colorIndicator"
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:background="#FF00AE42"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        <View
                android:id="@+id/colorBlock"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#FF00AE42"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
                android:id="@+id/filamentTypeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="PETG HF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1a1a1a"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                app:layout_constraintEnd_toStartOf="@+id/colorBlock"/>

        <TextView
                android:id="@+id/colorNameText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#555555"
                android:textStyle="bold"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@+id/filamentTypeText"
                app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                app:layout_constraintEnd_toStartOf="@+id/colorBlock"/>

        <TextView
                android:id="@+id/spoolWeightText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1000g"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginStart="6dp"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@+id/colorNameText"
                app:layout_constraintStart_toEndOf="@+id/colorIndicator"/>

        <TextView
                android:id="@+id/filamentLengthText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" · 82米"
                android:textSize="11sp"
                android:textColor="#888888"
                app:layout_constraintTop_toBottomOf="@+id/colorNameText"
                app:layout_constraintStart_toEndOf="@+id/spoolWeightText"/>

        <TextView
                android:id="@+id/UIDText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="UID: 15824C0D"
                android:textSize="10sp"
                android:textColor="#aaaaaa"
                android:layout_marginStart="6dp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                app:layout_constraintTop_toBottomOf="@+id/spoolWeightText"
                app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                app:layout_constraintEnd_toStartOf="@+id/colorBlock"/>

        <TextView
                android:id="@+id/productionDateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="2024/04/11"
                android:textSize="9sp"
                android:textColor="#cccccc"
                android:layout_marginStart="6dp"
                app:layout_constraintTop_toBottomOf="@+id/UIDText"
                app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                app:layout_constraintEnd_toStartOf="@+id/colorBlock"/>

        <TextView
                android:id="@+id/filamentColorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#00AE42"
                android:textSize="8sp"
                android:textColor="#999999"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@+id/colorBlock"
                app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
