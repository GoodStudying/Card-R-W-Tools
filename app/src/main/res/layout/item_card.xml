<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_marginHorizontal="8dp"
             android:layout_marginVertical="4dp">

    <androidx.cardview.widget.CardView
            android:id="@+id/card_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true">

        <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/content_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground">

            <View
                    android:id="@+id/colorIndicator"
                    android:layout_width="8dp"
                    android:layout_height="0dp"
                    android:background="#FF00AE42"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                    android:id="@+id/filamentTypeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="PETG HF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1a1a1a"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/colorPreview"/>

            <TextView
                    android:id="@+id/colorNameText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@+id/filamentTypeText"
                    app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/colorPreview"/>

            <LinearLayout
                    android:id="@+id/infoLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintTop_toBottomOf="@+id/colorNameText"
                    app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/colorPreview">

                <TextView
                        android:id="@+id/spoolWeightText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1000g"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textSize="13sp"
                        android:textColor="#888888"/>

                <TextView
                        android:id="@+id/filamentLengthText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="82米"
                        android:textSize="13sp"
                        android:textColor="#888888"/>

            </LinearLayout>

            <TextView
                    android:id="@+id/UIDText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="UID: 15824C0D"
                    android:textSize="12sp"
                    android:textColor="#aaaaaa"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@+id/infoLayout"
                    app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/colorPreview"/>

            <TextView
                    android:id="@+id/productionDateText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="2024/04/11"
                    android:textSize="11sp"
                    android:textColor="#cccccc"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="2dp"
                    app:layout_constraintTop_toBottomOf="@+id/UIDText"
                    app:layout_constraintStart_toEndOf="@+id/colorIndicator"
                    app:layout_constraintEnd_toStartOf="@+id/colorPreview"/>

            <TextView
                    android:id="@+id/filamentColorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#00AE42"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toTopOf="@+id/colorPreview"/>

            <LinearLayout
                    android:id="@+id/colorPreview"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/color_preview_bg"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                <View
                        android:id="@+id/colorBlock"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="#FF00AE42"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>
